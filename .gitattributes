# Auto detect text files and normalize line endings to LF
* text=auto

# Source files
*.py text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf
*.bash text eol=lf

# Windows files
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.db binary
*.sqlite binary
*.sqlite3 binary
*.pyc binary
*.pkl binary
*.pickle binary
